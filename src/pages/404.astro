---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Página no encontrada" description="La página que buscas no existe. Vuelve al portfolio de Eduardo Cabral." noindex={true}>
  <div class="flex min-h-screen items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">¡Ups! Página no encontrada</p>
      <a href="/" class="text-primary underline hover:text-primary/90 transition-colors">
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>